type Order {
    price: Float
    netAmount: Float
    category: String
    item: String
    quantity: Int
    status: String
}

input CreateOrderInput {
    price: Float!
    netAmount: Float!
    category: String!
    item: String!
    quantity: Int!
}

type Query {
    getOrders: [Order]
}

type Mutation {
    createOrder(input: CreateOrderInput!): Order
}