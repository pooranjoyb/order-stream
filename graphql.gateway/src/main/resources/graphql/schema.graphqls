# order type
type Order {
    id: Int,
    price: Float,
    netAmount: Float,
    category: String,
    item: String,
    quantity: Int,
    status: String
}

input OrderInput {
    price: Float!,
    category: String!,
    item: String!,
    quantity: Int!
}

# queries
type Query {
    getOrders: [Order],
    getOrder(id: ID!): Order
}

type Mutation {
    createOrder(order: OrderInput!): Order,
    updateOrder(id: ID!, order: OrderInput!): Order,
    deleteOrder(id: ID!): Boolean
}
